# ============================================================
# Riscala AI for ISMS 環境変数テンプレート
# コピーして .env.local を作成してください: cp .env.example .env.local
# 実キーが無くても、以下の既定値（スタブ動作）で全フローが通ります。
# ============================================================

# --- Database (libSQL/Turso) ---
DATABASE_MODE=sqlite                    # 'sqlite'（ローカル） | 'turso'（クラウド）
TURSO_DATABASE_URL=file:local.db        # ローカル開発の既定
# TURSO_DATABASE_URL=libsql://xxx.turso.io   # Turso Cloud 利用時
# TURSO_AUTH_TOKEN=                          # Turso Cloud 認証トークン

# --- Better Auth ---
BETTER_AUTH_SECRET=replace-with-openssl-rand-hex-32   # openssl rand -hex 32 で生成
# NEXT_PUBLIC_REQUIRE_EMAIL_VERIFICATION=false        # メール確認必須化（既定: 無効）
# NEXT_PUBLIC_AUTH_SSO_PROVIDERS=                     # SSOプロバイダ（カンマ区切り、既定: なし）

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3007

# --- Public demo reset (Vercel Cron) ---
# CRON_SECRET=replace-with-random-secret
DEMO_RESET_ENABLED=false
DEMO_RESET_DATABASE_NAME=pjt007-isms-public

# --- Stripe（未設定 or STRIPE_TEST_MODE=mock でモック動作） ---
# モックモードでは チェックアウト/購読作成/プラン変更/解約 が実キーなしで通り、
# 顧客ポータルは /mock/portal に遷移します。
STRIPE_TEST_MODE=mock                   # 'mock' で明示的にモック化（キー未設定でも自動モック）
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# --- メール送信（未設定ならコンソール出力スタブ） ---
# RESEND_API_KEY=                       # 未設定時: 招待/通知メールはサーバーログに出力
# INVITE_EMAIL_FROM=Riscala AI for ISMS <no-reply@riscala-isms.test>

# --- AI（未設定ならモック応答） ---
AI_PROVIDER_MODE=mock                   # 'mock' | 'claude' | 'ollama'
# ANTHROPIC_API_KEY=                    # claude モード利用時のみ必要
# OLLAMA_ENDPOINT=http://localhost:11434
# OLLAMA_MODEL=llama3
# OLLAMA_TIMEOUT_MS=30000

# --- 添付ファイルストレージ（常にローカルFS: .storage/ 配下） ---
# STORAGE_SIGNING_KEY=local-dev-key     # 署名付きURLのHMACシークレット（既定: local-dev-key）
