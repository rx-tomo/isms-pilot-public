# Copy this file to .env.local for local development.
# Do not commit real secrets.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3007
BETTER_AUTH_URL=http://localhost:3007
BETTER_AUTH_SECRET=replace-with-openssl-rand-hex-32

# Database
DATABASE_MODE=sqlite
TURSO_DATABASE_URL=file:local.db
# TURSO_DATABASE_URL=libsql://your-database.turso.io
# TURSO_AUTH_TOKEN=

# Stripe
# Leave mock mode enabled unless you are testing with your own Stripe account.
STRIPE_TEST_MODE=mock
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Email
# RESEND_API_KEY=
# INVITE_EMAIL_FROM=ISMS Pilot <no-reply@example.com>

# AI assistant
AI_PROVIDER_MODE=mock
# ANTHROPIC_API_KEY=
# OLLAMA_ENDPOINT=http://localhost:11434
# OLLAMA_MODEL=llama3

# Local file storage
# STORAGE_SIGNING_KEY=replace-with-local-development-secret
