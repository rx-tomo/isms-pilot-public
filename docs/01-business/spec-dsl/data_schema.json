{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://riscala-isms.local/spec-dsl/data_schema.json",
  "title": "Riscala AI for ISMS Implemented Business Data Schema",
  "version": "0.1.0",
  "last_updated": "2026-06-08",
  "source_note": "Derived from lib/db/drizzle/schema/** and selected API route payloads. Nullable DB text timestamps are represented as string|null.",
  "$defs": {
    "UuidText": {
      "type": "string",
      "minLength": 1
    },
    "IsoDateTimeText": {
      "type": ["string", "null"],
      "description": "ISO8601 string in current SQLite-compatible schema; null where column is nullable."
    },
    "JsonString": {
      "type": ["string", "null"],
      "description": "JSON serialized into TEXT in SQLite-compatible schema."
    },
    "Organization": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "$ref": "#/$defs/UuidText" },
        "name": { "type": "string" },
        "plan": { "enum": ["trial", "starter", "standard", "enterprise"], "source_status": "partially_confirmed" },
        "trial_ends_at": { "$ref": "#/$defs/IsoDateTimeText" },
        "is_active": { "type": ["boolean", "null"] }
      },
      "additionalProperties": true
    },
    "UserProfile": {
      "type": "object",
      "required": ["id", "email", "full_name", "role"],
      "properties": {
        "id": { "$ref": "#/$defs/UuidText" },
        "organization_id": { "$ref": "#/$defs/UuidText" },
        "email": { "type": "string", "format": "email" },
        "full_name": { "type": "string" },
        "full_name_en": { "type": ["string", "null"] },
        "role": { "enum": ["super_admin", "system_operator", "org_admin", "user", "auditor", "approver"] },
        "language_preference": { "enum": ["ja", "en", null] },
        "is_active": { "type": ["boolean", "null"], "default": true },
        "primary_department_id": { "type": ["string", "null"] },
        "is_ciso": { "type": ["boolean", "null"], "default": false },
        "is_security_manager": { "type": ["boolean", "null"], "default": false },
        "is_org_admin": { "type": ["boolean", "null"], "default": false },
        "is_audit_committee": { "type": ["boolean", "null"], "default": false },
        "is_isms_promoter": { "type": ["boolean", "null"], "default": false }
      },
      "additionalProperties": true
    },
    "Document": {
      "type": "object",
      "required": ["id", "organization_id", "title", "created_by"],
      "properties": {
        "id": { "$ref": "#/$defs/UuidText" },
        "organization_id": { "$ref": "#/$defs/UuidText" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": ["string", "null"] },
        "file_name": { "type": ["string", "null"] },
        "file_path": { "type": ["string", "null"] },
        "file_size": { "type": ["integer", "null"], "minimum": 0 },
        "mime_type": { "type": ["string", "null"] },
        "version_number": { "type": ["integer", "null"], "minimum": 1, "default": 1 },
        "status": { "enum": ["draft", "in_review", "approved", "obsolete", null], "default": "draft" },
        "category": { "type": ["string", "null"] },
        "tags": { "$ref": "#/$defs/JsonString" },
        "folder_id": { "type": ["string", "null"] },
        "created_by": { "$ref": "#/$defs/UuidText" },
        "updated_by": { "type": ["string", "null"] },
        "approved_by": { "type": ["string", "null"] },
        "approved_at": { "$ref": "#/$defs/IsoDateTimeText" },
        "retention_delete_at": { "$ref": "#/$defs/IsoDateTimeText" }
      },
      "additionalProperties": true
    },
    "CreateDocumentRequest": {
      "type": "object",
      "required": ["document"],
      "properties": {
        "document": {
          "type": "object",
          "required": ["organization_id", "title", "status"],
          "properties": {
            "organization_id": { "$ref": "#/$defs/UuidText" },
            "title": { "type": "string", "minLength": 1 },
            "description": { "type": ["string", "null"] },
            "category": { "type": ["string", "null"] },
            "folder_id": { "type": ["string", "null"] },
            "tags": { "type": ["string", "null"] },
            "file_name": { "type": ["string", "null"] },
            "file_path": { "type": ["string", "null"] },
            "file_size": { "type": ["integer", "null"], "minimum": 0 },
            "mime_type": { "type": ["string", "null"] },
            "retention_delete_at": { "$ref": "#/$defs/IsoDateTimeText" },
            "approved_at": { "$ref": "#/$defs/IsoDateTimeText" },
            "approved_by": { "type": ["string", "null"] },
            "status": { "enum": ["draft", "in_review", "approved", "obsolete"] }
          },
          "additionalProperties": true
        },
        "userId": {
          "type": ["string", "null"],
          "description": "Present in interface for compatibility but route uses authenticated user.id."
        }
      },
      "additionalProperties": false
    },
    "ApprovalRequest": {
      "type": "object",
      "required": ["id", "organization_id", "resource_type", "resource_id", "status", "requested_at"],
      "properties": {
        "id": { "$ref": "#/$defs/UuidText" },
        "organization_id": { "$ref": "#/$defs/UuidText" },
        "resource_type": {
          "enum": ["document", "audit_plan", "audit_report", "nonconformity_closure", "followup_record", "incident", "iso_control_soa", "risk_residual_acceptance"]
        },
        "resource_id": { "$ref": "#/$defs/UuidText" },
        "status": { "enum": ["pending", "approved", "rejected", "expired"] },
        "requested_by": { "type": ["string", "null"] },
        "approver_id": { "type": ["string", "null"] },
        "approved_at": { "$ref": "#/$defs/IsoDateTimeText" },
        "rejection_reason": { "type": ["string", "null"] },
        "due_at": { "$ref": "#/$defs/IsoDateTimeText" },
        "step_number": { "type": ["integer", "null"], "minimum": 1 },
        "reverted_at": { "$ref": "#/$defs/IsoDateTimeText" },
        "revert_reason": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "Risk": {
      "type": "object",
      "required": ["id", "title"],
      "properties": {
        "id": { "$ref": "#/$defs/UuidText" },
        "organization_id": { "type": ["string", "null"] },
        "category_id": { "type": ["string", "null"] },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": ["string", "null"] },
        "impact_level": { "type": ["integer", "null"], "minimum": 1, "maximum": 5 },
        "likelihood_level": { "type": ["integer", "null"], "minimum": 1, "maximum": 5 },
        "risk_score": { "type": ["integer", "null"], "minimum": 1, "maximum": 25, "description": "Computed at application layer as impact_level * likelihood_level." },
        "status": { "enum": ["identified", "analyzing", "treating", "monitoring", "closed", null], "default": "identified" },
        "identified_date": { "$ref": "#/$defs/IsoDateTimeText" },
        "identified_by": { "type": ["string", "null"] },
        "owner_id": { "type": ["string", "null"] },
        "assessment_period": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "RiskTreatment": {
      "type": "object",
      "required": ["id", "risk_id", "treatment_type"],
      "properties": {
        "id": { "$ref": "#/$defs/UuidText" },
        "risk_id": { "$ref": "#/$defs/UuidText" },
        "organization_id": { "type": ["string", "null"] },
        "treatment_type": { "enum": ["mitigate", "transfer", "accept", "avoid", null] },
        "treatment_description": { "type": ["string", "null"] },
        "responsible_person_id": { "type": ["string", "null"] },
        "target_date": { "$ref": "#/$defs/IsoDateTimeText" },
        "status": { "enum": ["planned", "in_progress", "completed", "cancelled", null] },
        "residual_risk_score": { "type": ["integer", "null"], "minimum": 1, "maximum": 25 },
        "residual_approval_status": { "enum": ["draft", "submitted", "approved", "rejected", null], "default": "draft" },
        "residual_approved_by": { "type": ["string", "null"] },
        "residual_approved_at": { "$ref": "#/$defs/IsoDateTimeText" },
        "residual_rejection_reason": { "type": ["string", "null"] },
        "residual_review_due_date": { "$ref": "#/$defs/IsoDateTimeText" }
      },
      "additionalProperties": true
    },
    "SoaVersion": {
      "type": "object",
      "required": ["id", "organization_id", "version_number", "snapshot", "control_count", "approved_control_count", "published_at"],
      "properties": {
        "id": { "$ref": "#/$defs/UuidText" },
        "organization_id": { "$ref": "#/$defs/UuidText" },
        "version_number": { "type": "integer", "minimum": 1 },
        "title": { "type": ["string", "null"] },
        "change_summary": {
          "type": ["string", "null"],
          "description": "SoA版を発行した理由、前版からの見直し理由、審査前レビュー等の改訂説明を保持する。"
        },
        "snapshot": {
          "type": "string",
          "description": "SoA発行時点の管理策、判断、理由、承認状態、関連リスク/対応策をJSON文字列として固定する。"
        },
        "control_count": { "type": "integer", "minimum": 0 },
        "approved_control_count": { "type": "integer", "minimum": 0 },
        "published_by": { "type": ["string", "null"] },
        "published_at": { "$ref": "#/$defs/IsoDateTimeText" },
        "review_status": {
          "type": "string",
          "enum": ["draft", "submitted", "approved", "rejected"],
          "description": "SoA全体版のレビュー状態。"
        },
        "reviewed_by": { "type": ["string", "null"] },
        "reviewed_at": { "$ref": "#/$defs/IsoDateTimeText" },
        "rejection_reason": { "type": ["string", "null"] },
        "created_at": { "$ref": "#/$defs/IsoDateTimeText" }
      },
      "additionalProperties": true
    },
    "InformationAsset": {
      "type": "object",
      "required": ["id", "organization_id", "name"],
      "properties": {
        "id": { "$ref": "#/$defs/UuidText" },
        "organization_id": { "$ref": "#/$defs/UuidText" },
        "name": { "type": "string", "minLength": 1 },
        "asset_type": { "enum": ["hardware", "software", "data", "service", "facility", "personnel", "other", null], "default": "data" },
        "classification": { "enum": ["restricted", "internal", "public", null], "default": "internal" },
        "criticality": { "enum": ["low", "medium", "high", null], "default": "medium" },
        "owner_id": { "type": ["string", "null"] },
        "location": { "type": ["string", "null"] },
        "status": { "enum": ["in_use", "retired", "planned", null], "default": "in_use" },
        "description": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "AuditPlan": {
      "type": "object",
      "required": ["id", "title"],
      "properties": {
        "id": { "$ref": "#/$defs/UuidText" },
        "organization_id": { "type": ["string", "null"] },
        "title": { "type": "string", "minLength": 1 },
        "audit_type": { "enum": ["internal", "external", "certification", "surveillance", null] },
        "standard": { "type": ["string", "null"], "default": "ISO27001" },
        "planned_start_date": { "$ref": "#/$defs/IsoDateTimeText" },
        "planned_end_date": { "$ref": "#/$defs/IsoDateTimeText" },
        "lead_auditor_id": { "type": ["string", "null"] },
        "status": { "enum": ["planning", "scheduled", "in_progress", "completed", "cancelled", null], "default": "planning" },
        "audit_period": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "AuditReport": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "$ref": "#/$defs/UuidText" },
        "audit_plan_id": { "type": ["string", "null"] },
        "approval_status": { "enum": ["draft", "submitted", "approved", "rejected", null] },
        "approved_by": { "type": ["string", "null"] },
        "approved_at": { "$ref": "#/$defs/IsoDateTimeText" },
        "rejection_reason": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "AIRiskAnalyzeRequest": {
      "type": "object",
      "required": ["type", "context"],
      "properties": {
        "type": { "enum": ["identify", "evaluate", "suggest_treatments"] },
        "context": {
          "oneOf": [
            {
              "type": "object",
              "required": ["assetName", "assetType"],
              "properties": {
                "assetName": { "type": "string", "minLength": 1 },
                "assetType": { "type": "string", "minLength": 1 },
                "description": { "type": "string" },
                "department": { "type": "string" }
              },
              "additionalProperties": true
            },
            {
              "type": "object",
              "required": ["riskName", "riskCategory"],
              "properties": {
                "riskName": { "type": "string", "minLength": 1 },
                "riskCategory": { "type": "string", "minLength": 1 },
                "description": { "type": "string" },
                "assetName": { "type": "string" },
                "currentImpact": { "type": "integer" },
                "currentLikelihood": { "type": "integer" },
                "existingControls": { "type": "array", "items": { "type": "string" } }
              },
              "additionalProperties": true
            }
          ]
        },
        "riskId": { "type": "string" },
        "options": {
          "type": "object",
          "properties": {
            "useCache": { "type": "boolean", "default": true },
            "saveSuggestion": { "type": "boolean", "default": true }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
